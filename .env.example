# ─────────────────────────────────────────────────────────────
# Phishing Detection System — environment variable reference
# Copy this file to .env and fill in real values before deploying.
# Never commit your actual .env to version control.
# ─────────────────────────────────────────────────────────────

# PostgreSQL password (used by both the db and backend services)
POSTGRES_PASSWORD=change_me_before_deploy

# JWT signing key — must be a long, random hex string in production.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_before_deploy

# Full public URL of the backend API, as seen by the browser.
# In production this is your backend's domain, e.g. https://api.yourdomain.com
NEXT_PUBLIC_API_URL=http://localhost:8000
